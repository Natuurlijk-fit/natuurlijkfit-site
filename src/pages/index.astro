.comparison-table { width: 100%; border-collapse: collapse; font-size: 14px; margin-top: 2rem; }
.comparison-table th { padding: 12px 16px; text-align: left; font-size: 11px; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); background: var(--cream); font-weight: 500; border-bottom: 1px solid var(--border); }
.comparison-table th:last-child { color: var(--deep); background: var(--pale); }
.comparison-table td { padding: 12px 16px; border-bottom: 1px solid rgba(200,221,210,.4); font-weight: 300; }
.comparison-table td:last-child { font-weight: 500; color: var(--deep); background: rgba(216,243,220,.2); }
.comparison-table tr:last-child td { border-bottom: none; }
.check { color: var(--acc); }
.cross { color: #DC2626; }

/* ═══════════════════════════════════
   BLOG
═══════════════════════════════════ */
.blog-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; }

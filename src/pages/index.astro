.dossier-card {
  background: var(--ivory); border: 1px solid var(--border); border-radius: 8px; padding: 22px;
  cursor: pointer; transition: border-color .2s;
}
.dossier-card:hover { border-color: var(--acc); }
.dossier-badge { font-size: 10px; font-weight: 500; letter-spacing: .08em; text-transform: uppercase; color: var(--acc); margin-bottom: 8px; }
.dossier-name { font-size: 15px; font-weight: 500; color: var(--deep); margin-bottom: 4px; }
.dossier-desc { font-size: 12px; color: var(--muted); line-height: 1.55; font-weight: 300; margin-bottom: 14px; }
.dossier-meta { display: flex; gap: 10px; align-items: center; }
.dossier-meta span { font-size: 11px; color: var(--muted); }
.dossier-dl {
  font-size: 11px; font-weight: 500; letter-spacing: .06em; text-transform: uppercase;
  background: none; border: 1px solid var(--border); color: var(--deep); padding: 5px 11px;
  border-radius: 3px; cursor: pointer; font-family: var(--sans); margin-left: auto;
  transition: all .15s;
}
.dossier-dl:hover { background: var(--deep); border-color: var(--deep); color: #fff; }
.notion-sync {
  background: rgba(82,183,136,.08); border: 1px solid rgba(82,183,136,.3);
  border-radius: 6px; padding: 10px 16px; font-size: 12px; color: var(--mid);
  display: flex; align-items: center; gap: 8px; margin-bottom: 1.5rem;
}
.affiliate-ext-banner {
  background: var(--cream); border: 1px solid var(--border); border-radius: 8px;
  padding: 28px 24px; text-align: center;
}
.affiliate-ext-banner h3 { font-family: var(--serif); font-size: 1.4rem; color: var(--deep); margin-bottom: .5rem; }
.affiliate-ext-banner p { font-size: 14px; color: var(--muted); max-width: 480px; margin: 0 auto 1.5rem; font-weight: 300; }

/* ═══════════════════════════════════
   REGISTRATIE PAGINA
═══════════════════════════════════ */
.reg-wrap { max-width: 620px; margin: 0 auto; }
.form-group { margin-bottom: 1.2rem; }
.form-label { font-size: 13px; font-weight: 500; color: var(--deep); display: block; margin-bottom: 6px; letter-spacing: .02em; }
.form-label span { color: var(--muted); font-weight: 300; }
.form-input, .form-select, .form-textarea {
  width: 100%; padding: 11px 14px; font-size: 14px; font-family: var(--sans);
  border: 1px solid var(--border); border-radius: 4px; background: var(--ivory);
  color: var(--charcoal); outline: none; transition: border-color .2s;
}
.form-input:focus, .form-select:focus, .form-textarea:focus { border-color: var(--mid); }
.form-textarea { min-height: 90px; resize: vertical; }
.form-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.form-note { font-size: 12px; color: var(--muted); margin-top: 4px; font-weight: 300; }
.form-submit { margin-top: 2rem; }
.form-disclaimer { font-size: 12px; color: var(--muted); margin-top: 1rem; line-height: 1.6; font-weight: 300; }

/* ═══════════════════════════════════
   OVER ONS / FILOSOFIE
═══════════════════════════════════ */
.founder-layout { display: grid; grid-template-columns: 1fr 2.5fr; gap: 5rem; align-items: start; }
.founder-photo { aspect-ratio: 1; background: linear-gradient(135deg,var(--pale) 0%,var(--border) 100%); border-radius: 6px; display: flex; align-items: center; justify-content: center; }
.founder-initials { font-family: var(--serif); font-size: 3rem; color: var(--deep); opacity: .4; }
.timeline { display: flex; flex-direction: column; gap: 0; }
.timeline-item { display: grid; grid-template-columns: 80px 1fr; gap: 20px; padding: 20px 0; border-bottom: 1px solid var(--border); }
.timeline-item:first-child { border-top: 1px solid var(--border); }
.t-year { font-family: var(--serif); font-size: 1.1rem; color: var(--acc); font-weight: 500; padding-top: 3px; }
.t-title { font-size: 14px; font-weight: 500; color: var(--deep); margin-bottom: 4px; }
.t-desc  { font-size: 13px; color: var(--muted); line-height: 1.6; font-weight: 300; }

/* ═══════════════════════════════════

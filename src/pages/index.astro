---
---
<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Natuurlijk.fit — Healthcare & Advanced Sports Nutraceuticals</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════
   TOKENS
═══════════════════════════════════ */
:root {
  --deep:    #1B4332;
  --mid:     #2D6A4F;
  --acc:     #52B788;
  --pale:    #D8F3DC;
  --cream:   #F5F0E8;
  --ivory:   #FAFAF5;
  --charcoal:#0F1F18;
  --muted:   #4A6358;
  --border:  #C8DDD2;
  --serif:   'Cormorant Garamond', Georgia, serif;
  --sans:    'DM Sans', system-ui, sans-serif;
}

/* ═══════════════════════════════════
   RESET & BASE
═══════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--sans);
  background: var(--ivory);
  color: var(--charcoal);
  font-size: 16px;
  line-height: 1.7;
  -webkit-font-smoothing: antialiased;
}
a { color: inherit; text-decoration: none; }
img { max-width: 100%; }

/* ═══════════════════════════════════
   CSS-ONLY LOGO (swap voor <img> bij implementatie)
═══════════════════════════════════ */
.logo-css {
  display: flex;
  flex-direction: column;
  line-height: 1;
  cursor: pointer;
  /* ⚠️ PLACEHOLDER — vervang door:
     <img src="Logo-Natuurlijkfit.png" style="height:52px">  (lichte nav)
     <img src="Logo-Natuurlijkfit-White.png" style="height:48px"> (donkere footer) */
}
.logo-wordmark {
  font-family: var(--serif);
  font-weight: 600;
  font-size: 20px;
  letter-spacing: .07em;
  color: var(--deep);
  text-transform: uppercase;
  line-height: 1;
}
.logo-wordmark .dot { color: var(--acc); }
.logo-tagline {
  font-size: 8.5px;
  letter-spacing: .14em;
  color: var(--muted);
  text-transform: uppercase;
  margin-top: 3px;
}
.logo-css.white .logo-wordmark { color: #fff; }
.logo-css.white .logo-tagline  { color: rgba(255,255,255,.4); }

/* ═══════════════════════════════════
   ANNOUNCEMENT BAR
═══════════════════════════════════ */
#ann-bar {
  background: var(--deep);
  padding: 9px 5vw;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  letter-spacing: .05em;
  color: rgba(255,255,255,.75);
}
#ann-bar strong { color: var(--acc); font-weight: 500; }

/* ═══════════════════════════════════
   NAV
═══════════════════════════════════ */
nav {
  position: sticky;
  top: 0;
  z-index: 200;
  background: var(--ivory);
  border-bottom: 1px solid var(--border);
  padding: 0 4vw;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 68px;
  overflow: visible;
}
.nav-links { display: flex; align-items: center; gap: 2px; list-style: none; flex-wrap: nowrap; }
.nav-links li a, .nav-links li button {
  font-family: var(--sans);
  font-size: 12.5px;
  font-weight: 400;
  letter-spacing: .02em;
  color: var(--muted);
  padding: 6px 10px;
  border-radius: 4px;
  border: none;
  background: none;
  cursor: pointer;
  transition: color .2s, background .2s;
  white-space: nowrap;
}
.nav-links li a:hover, .nav-links li button:hover { color: var(--deep); background: var(--pale); }
.nav-links li a.nav-b2b {
  border: 1px solid var(--border);
  color: var(--deep);
  font-weight: 500;
}
.nav-links li a.nav-cta {
  background: var(--deep);
  color: #fff;
  font-weight: 500;
  padding: 8px 20px;
}
.nav-links li a.nav-cta:hover { background: var(--mid); }
.nav-sep { width: 1px; height: 20px; background: var(--border); margin: 0 4px; }

/* ═══════════════════════════════════
   PAGE ROUTING
═══════════════════════════════════ */
.page { display: none; }
.page.active { display: block; }

/* ═══════════════════════════════════
   SHARED SECTION ATOMS
═══════════════════════════════════ */
section { padding: 88px 5vw; }
.section-label {
  font-size: 10px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--acc);
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  gap: 10px;
  font-weight: 500;
}
.section-label::before { content: ''; width: 24px; height: 1px; background: var(--acc); }
h1.serif, h2.serif {
  font-family: var(--serif);
  font-weight: 500;
  line-height: 1.18;
  color: var(--deep);
}
h1.serif { font-size: clamp(2.4rem,4vw,3.6rem); }
h2.serif  { font-size: clamp(1.8rem,2.8vw,2.6rem); }
.lead { font-size: 16px; font-weight: 300; color: var(--muted); line-height: 1.85; max-width: 560px; }

.btn {
  display: inline-block;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: .06em;
  padding: 13px 26px;
  border-radius: 4px;
  border: none;
  cursor: pointer;
  text-transform: uppercase;
  transition: background .2s, color .2s, border-color .2s;
  font-family: var(--sans);
}
.btn-green  { background: var(--deep); color: #fff; }
.btn-green:hover { background: var(--mid); }
.btn-acc    { background: var(--acc); color: var(--deep); }
.btn-acc:hover { background: #6CD49A; }
.btn-outline { background: transparent; border: 1px solid var(--border); color: var(--deep); }
.btn-outline:hover { border-color: var(--mid); background: var(--pale); }
.btn-ghost-white { background: transparent; border: 1px solid rgba(255,255,255,.25); color: rgba(255,255,255,.85); }
.btn-ghost-white:hover { border-color: rgba(255,255,255,.5); color: #fff; }

/* badges */
.badge {
  display: inline-block;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: .09em;
  text-transform: uppercase;
  padding: 3px 9px;
  border-radius: 3px;
  border: 1px solid var(--border);
  color: var(--muted);
}
.badge-green { background: var(--pale); border-color: var(--acc); color: var(--deep); }
.badge-amber { background: #FEF3C7; border-color: #D97706; color: #92400E; }
.badge-lock  { background: #FEF3C7; border-color: #D97706; color: #92400E; }

/* ═══════════════════════════════════
   PILLARS STRIP
═══════════════════════════════════ */
.pillars-strip {
  background: var(--mid);
  padding: 18px 5vw;
  display: flex;
  overflow-x: auto;
}
.pillar-item {
  flex: 1; min-width: 170px;
  display: flex; align-items: center; gap: 12px;
  padding: 6px 22px;
  border-right: 1px solid rgba(255,255,255,.12);
}
.pillar-item:last-child { border-right: none; }
.p-icon {
  width: 30px; height: 30px; flex-shrink: 0;
  border: 1px solid rgba(255,255,255,.3);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.p-text { color: rgba(255,255,255,.9); font-size: 12px; font-weight: 500; line-height: 1.25; }
.p-text span { display: block; color: rgba(255,255,255,.45); font-size: 11px; font-weight: 300; }

/* ═══════════════════════════════════
   CARDS
═══════════════════════════════════ */
.card {
  background: var(--ivory);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 28px 22px;
  transition: border-color .2s, transform .2s;
}
.card:hover { border-color: var(--acc); transform: translateY(-2px); }
.card-title { font-size: 14px; font-weight: 500; color: var(--deep); margin-bottom: 6px; }
.card-sub   { font-size: 13px; color: var(--muted); line-height: 1.6; font-weight: 300; }

/* ═══════════════════════════════════
   FOOTER
═══════════════════════════════════ */
footer {
  background: var(--charcoal);
  padding: 64px 5vw 40px;
}
.footer-top {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 3rem;
  padding-bottom: 48px;
  border-bottom: 1px solid rgba(255,255,255,.07);
}
.footer-brand p { font-size: 13px; color: rgba(255,255,255,.38); line-height: 1.8; margin-top: 1rem; max-width: 280px; font-weight: 300; }
footer h4 { font-size: 10px; letter-spacing: .18em; text-transform: uppercase; color: rgba(255,255,255,.28); margin-bottom: 1.2rem; }
footer ul { list-style: none; }
footer ul li { margin-bottom: 7px; }
footer ul a, footer ul button {
  font-size: 13px; color: rgba(255,255,255,.5);
  font-weight: 300; border: none; background: none;
  cursor: pointer; font-family: var(--sans); padding: 0;
  transition: color .2s;
}
footer ul a:hover, footer ul button:hover { color: rgba(255,255,255,.9); }
.footer-ext { color: rgba(255,255,255,.3) !important; font-size: 11px !important; }
.footer-ext::after { content: ' ↗'; font-size: 9px; }
.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 32px;
  font-size: 12px;
  color: rgba(255,255,255,.18);
}
.footer-bottom a { color: rgba(255,255,255,.25); }
.footer-bottom a:hover { color: rgba(255,255,255,.6); }

/* ═══════════════════════════════════
   HERO (HOME)
═══════════════════════════════════ */
.hero {
  background: var(--deep);
  min-height: 90vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  padding: 0 5vw;
  gap: 4rem;
  position: relative;
  overflow: hidden;
}
.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 11px; letter-spacing: .2em; text-transform: uppercase;
  color: var(--acc); margin-bottom: 2rem; font-weight: 500;
}
.hero-eyebrow::before { content: ''; width: 28px; height: 1px; background: var(--acc); }
.hero h1 {
  font-family: var(--serif);
  font-size: clamp(2.6rem,4.5vw,4rem);
  font-weight: 500;
  line-height: 1.15;
  color: var(--cream);
  margin-bottom: 1.5rem;
}
.hero h1 em { font-style: italic; color: var(--acc); }
.hero .hero-desc { font-size: 15px; line-height: 1.85; color: rgba(245,240,232,.62); max-width: 480px; margin-bottom: 2.5rem; font-weight: 300; }
.hero-actions { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; margin-bottom: 2.5rem; }
.hero-stats {
  display: flex; gap: 0;
  border-top: 1px solid rgba(255,255,255,.1);
  padding-top: 1.8rem;
}
.hero-stat { padding-right: 2rem; border-right: 1px solid rgba(255,255,255,.1); margin-right: 2rem; }
.hero-stat:last-child { border-right: none; margin-right: 0; }
.hero-stat-num { font-family: var(--serif); font-size: 2rem; color: var(--cream); font-weight: 400; line-height: 1; margin-bottom: 4px; }
.hero-stat-label { font-size: 10px; color: rgba(245,240,232,.4); letter-spacing: .09em; text-transform: uppercase; }
.hero-mol { opacity: .13; display: flex; justify-content: flex-end; align-items: center; }
.hero-mol svg { width: min(340px,38vw); }

/* ═══════════════════════════════════
   HOME — SECONDARY SECTIONS
═══════════════════════════════════ */
.split-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
.split-2-center { align-items: center; }
.philosophy-quote {
  border-left: 2px solid var(--acc); padding-left: 1.5rem;
  margin: 2rem 0;
  font-family: var(--serif); font-size: 1.3rem; font-style: italic;
  color: var(--mid); line-height: 1.5;
}
.pillar-list { display: flex; flex-direction: column; }
.pillar-row {
  display: grid; grid-template-columns: 48px 1fr;
  gap: 14px; padding: 18px 0;
  border-bottom: 1px solid var(--border); align-items: start;
}
.pillar-row:first-child { border-top: 1px solid var(--border); }
.pnum { font-family: var(--serif); font-size: 1.4rem; color: var(--border); font-weight: 400; padding-top: 2px; }
.plabel { font-size: 13px; font-weight: 500; color: var(--deep); letter-spacing: .04em; text-transform: uppercase; margin-bottom: 3px; }
.pdesc  { font-size: 13px; color: var(--muted); line-height: 1.6; font-weight: 300; }

/* product grid home */
.product-grid { display: grid; grid-template-columns: repeat(5,1fr); gap: 14px; }
.product-icon { width: 42px; height: 42px; background: var(--pale); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 14px; }

/* professionals dark section */
.section-dark { background: var(--deep); color: var(--cream); }
.section-dark .section-label::before { background: var(--acc); }
.section-dark h2.serif { color: var(--cream); }
.section-dark h2.serif em { font-style: italic; color: var(--acc); }
.section-dark p { color: rgba(245,240,232,.6); font-size: 15px; line-height: 1.85; font-weight: 300; margin-bottom: 1rem; }
.pro-list { display: flex; flex-direction: column; }
.pro-row {
  display: grid; grid-template-columns: 28px 1fr;
  gap: 14px; padding: 18px 0;
  border-bottom: 1px solid rgba(255,255,255,.08); align-items: start;
}
.pro-row:first-child { border-top: 1px solid rgba(255,255,255,.08); }
.pro-dot { width: 18px; height: 18px; border: 1px solid var(--acc); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-top: 3px; flex-shrink: 0; }
.pro-dot::after { content: ''; width: 7px; height: 7px; background: var(--acc); border-radius: 50%; }
.pro-rtitle { font-size: 13px; font-weight: 500; color: var(--cream); margin-bottom: 3px; }
.pro-rdesc  { font-size: 13px; color: rgba(245,240,232,.48); font-weight: 300; line-height: 1.5; }

/* quality grid */
.quality-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 20px; }
.q-item { background: var(--ivory); border: 1px solid var(--border); border-radius: 6px; padding: 28px 20px; text-align: center; }
.q-glyph { font-family: var(--serif); font-size: 2rem; color: var(--deep); opacity: .3; display: block; margin-bottom: 10px; font-style: italic; }
.q-title { font-size: 12px; font-weight: 500; color: var(--deep); letter-spacing: .07em; text-transform: uppercase; margin-bottom: 7px; }
.q-desc  { font-size: 13px; color: var(--muted); line-height: 1.55; font-weight: 300; }

/* ═══════════════════════════════════
   WEBSHOP PAGE
═══════════════════════════════════ */
.shop-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2.5rem; flex-wrap: wrap; gap: 1rem; }
.filter-bar { display: flex; gap: 8px; flex-wrap: wrap; }
.filter-btn {
  font-size: 12px; font-weight: 500; letter-spacing: .04em;
  padding: 6px 14px; border-radius: 20px;
  border: 1px solid var(--border); background: none;
  color: var(--muted); cursor: pointer; font-family: var(--sans);
  transition: all .15s;
}
.filter-btn.active { background: var(--deep); border-color: var(--deep); color: #fff; }
.filter-btn:hover:not(.active) { border-color: var(--mid); color: var(--deep); }
.product-list { display: grid; grid-template-columns: repeat(4,1fr); gap: 20px; }
.product-item {
  background: var(--ivory); border: 1px solid var(--border); border-radius: 8px;
  overflow: hidden; cursor: pointer;
  transition: border-color .2s, transform .2s;
}
.product-item:hover { border-color: var(--acc); transform: translateY(-2px); }
.product-img {
  background: var(--cream);
  height: 180px;
  display: flex; align-items: center; justify-content: center;
  border-bottom: 1px solid var(--border);
}
.product-img svg { opacity: .25; }
.product-info { padding: 18px 16px; }
.product-name { font-size: 14px; font-weight: 500; color: var(--deep); margin-bottom: 4px; }
.product-cat  { font-size: 11px; letter-spacing: .06em; text-transform: uppercase; color: var(--acc); margin-bottom: 8px; }
.product-tagline { font-size: 12px; color: var(--muted); line-height: 1.5; font-weight: 300; margin-bottom: 12px; }
.product-bottom { display: flex; justify-content: space-between; align-items: center; }
.product-price { font-family: var(--serif); font-size: 1.1rem; color: var(--deep); font-weight: 500; }
.product-add {
  font-size: 11px; font-weight: 500; letter-spacing: .06em; text-transform: uppercase;
  background: var(--deep); color: #fff; padding: 6px 12px; border-radius: 3px; border: none;
  cursor: pointer; font-family: var(--sans); transition: background .15s;
}
.product-add:hover { background: var(--mid); }
.notion-note {
  background: var(--pale); border: 1px solid var(--acc); border-radius: 6px;
  padding: 12px 18px; font-size: 13px; color: var(--deep); margin-bottom: 2rem;
  display: flex; align-items: center; gap: 10px;
}
.notion-icon { font-size: 16px; flex-shrink: 0; }

/* ═══════════════════════════════════
   SINGLE PRODUCT PAGE
═══════════════════════════════════ */
.product-single { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
.product-visual {
  background: var(--cream); border: 1px solid var(--border); border-radius: 8px;
  min-height: 420px; display: flex; align-items: center; justify-content: center;
}
.product-visual svg { opacity: .2; }
.product-cats { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 1.2rem; }
.product-detail-name { font-family: var(--serif); font-size: 2rem; font-weight: 500; color: var(--deep); line-height: 1.2; margin-bottom: .5rem; }
.product-detail-sub { font-size: 13px; color: var(--muted); font-weight: 300; margin-bottom: 1.5rem; }
.ingr-list { border: 1px solid var(--border); border-radius: 6px; overflow: hidden; margin: 1.5rem 0; }
.ingr-head { background: var(--cream); padding: 10px 16px; font-size: 11px; font-weight: 500; color: var(--deep); letter-spacing: .06em; text-transform: uppercase; border-bottom: 1px solid var(--border); }
.ingr-row { display: flex; justify-content: space-between; padding: 9px 16px; border-bottom: 1px solid rgba(200,221,210,.4); font-size: 13px; }
.ingr-row:last-child { border-bottom: none; }
.ingr-name { color: var(--deep); font-weight: 400; }
.ingr-val  { color: var(--muted); font-weight: 300; }
.locked-block {
  background: var(--cream); border: 1px solid #D97706; border-radius: 6px;
  padding: 20px 22px; margin-top: 1.5rem;
}
.locked-title { font-size: 13px; font-weight: 500; color: var(--deep); margin-bottom: 4px; display: flex; align-items: center; gap: 8px; }
.locked-desc { font-size: 13px; color: var(--muted); font-weight: 300; margin-bottom: 14px; line-height: 1.6; }
.lock-icon { font-size: 14px; }

/* ═══════════════════════════════════
   VOOR THERAPEUTEN LANDING
═══════════════════════════════════ */
.ther-hero {
  background: var(--deep); padding: 96px 5vw;
  text-align: center;
}
.ther-hero h1 { color: var(--cream); margin-bottom: 1.2rem; }
.ther-hero .lead { color: rgba(245,240,232,.6); margin: 0 auto 2.5rem; text-align: center; }
.ther-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
.ther-card { background: var(--ivory); border: 1px solid var(--border); border-radius: 8px; padding: 28px 22px; }
.ther-icon-wrap { width: 44px; height: 44px; background: var(--pale); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; }
.ther-num { font-family: var(--serif); font-size: 2rem; color: var(--pale); font-weight: 400; margin-bottom: 12px; }
.target-table { width: 100%; border-collapse: collapse; font-size: 14px; }
.target-table th { text-align: left; padding: 10px 16px; font-size: 11px; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); background: var(--cream); border-bottom: 1px solid var(--border); font-weight: 500; }
.target-table td { padding: 12px 16px; border-bottom: 1px solid rgba(200,221,210,.4); color: var(--charcoal); font-weight: 300; vertical-align: top; }
.target-table tr:last-child td { border-bottom: none; }
.process-steps { display: grid; grid-template-columns: repeat(4,1fr); gap: 0; }
.step { padding: 28px 22px; position: relative; }
.step:not(:last-child)::after {
  content: '→'; position: absolute; right: -10px; top: 50%; transform: translateY(-50%);
  color: var(--acc); font-size: 1.2rem; z-index: 1;
}
.step-num { font-family: var(--serif); font-size: 2.5rem; color: var(--border); font-weight: 400; line-height: 1; margin-bottom: 10px; }
.step-title { font-size: 14px; font-weight: 500; color: var(--deep); margin-bottom: 4px; }
.step-desc { font-size: 12px; color: var(--muted); line-height: 1.5; font-weight: 300; }

/* ═══════════════════════════════════
   THERAPEUTENPORTAL (INGELOGD)
═══════════════════════════════════ */
.portal-layout { display: grid; grid-template-columns: 220px 1fr; gap: 3rem; align-items: start; }
.portal-sidebar { position: sticky; top: 90px; }
.sidebar-user { padding: 16px; background: var(--cream); border-radius: 8px; border: 1px solid var(--border); margin-bottom: 16px; }
.sidebar-avatar { width: 40px; height: 40px; background: var(--deep); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-family: var(--serif); font-size: 1rem; margin-bottom: 8px; }
.sidebar-name { font-size: 13px; font-weight: 500; color: var(--deep); }
.sidebar-role { font-size: 11px; color: var(--acc); letter-spacing: .04em; }
.sidebar-nav { list-style: none; }
.sidebar-nav li button {
  width: 100%; text-align: left; padding: 9px 12px; font-size: 13px;
